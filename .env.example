# ========================
# FreelancerAI - Root .env
# Copy to contracts/.env, backend/.env, and frontend/.env.local
# ========================

# --- Blockchain ---
PRIVATE_KEY=your_deployer_wallet_private_key_here
RPC_URL=https://testnet-rpc.monad.xyz

# Deployed contract addresses (filled in after running deploy.ts)
MARKETPLACE_ADDRESS=0x...
ESCROW_ADDRESS=0x...
REPUTATION_ADDRESS=0x...
PORTFOLIO_PROOF_ADDRESS=0x...
AGENT_REGISTRY_ADDRESS=0x...

# The AI agent's Monad wallet address
AGENT_WALLET_ADDRESS=0x...

# --- Firebase (Admin SDK - Backend) ---
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# --- Firebase (Client SDK - Frontend) ---
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcdef123456

# --- Gemini AI ---
GEMINI_API_KEY=your-gemini-api-key-here

# --- Frontend Public Env (mirrors contract addresses) ---
NEXT_PUBLIC_MARKETPLACE_ADDRESS=0x...
NEXT_PUBLIC_ESCROW_ADDRESS=0x...
NEXT_PUBLIC_REPUTATION_ADDRESS=0x...
NEXT_PUBLIC_AGENT_ADDRESS=0x...
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_RPC_URL=https://testnet-rpc.monad.xyz

# --- Cloud Run Backend ---
PORT=3001
NODE_ENV=development
